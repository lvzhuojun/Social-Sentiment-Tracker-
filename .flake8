[flake8]
max-line-length = 100
# E203: whitespace before ':' (conflicts with black)
# W503: line break before binary operator (conflicts with black)
# E402: module level import not at top — intentional in src/ modules that need sys.path.insert
extend-ignore = E203, W503, E402
exclude =
    __pycache__,
    .git,
    .venv,
    venv,
    build,
    dist,
    notebooks,
    .github
